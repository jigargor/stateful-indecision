ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...        # optional when using Anthropic; for openai provider use unless OPENAI_BASE_URL is set (local servers often ignore the key)
# OPENAI_BASE_URL=           # optional — OpenAI-compatible API base URL (Ollama / LM Studio / vLLM); can also set run_config key openai_base_url
# SCITE_API_KEY=...
# SCITE_PARTNER_KEY=...
# ZOTERO_API_KEY=...
# ZOTERO_LIBRARY_ID=...

# --- S3 Offload (optional, requires pip install '.[s3]') ---
# S3_OFFLOAD_ENABLED=1
# S3_OFFLOAD_BUCKET=my-stateful-indecision-bucket
# S3_OFFLOAD_PREFIX=prod
# AWS_REGION=us-east-1
# S3_SYNC_INTERVAL_SEC=300
# S3_SYNC_MIN_BYTES=4096
# S3_SHUTDOWN_MAX_SEC=90
# S3_RESEARCH_MODE=bundle
# S3_SSE=sse-s3
# S3_KMS_KEY_ID=
# S3_STATE_PATH=
