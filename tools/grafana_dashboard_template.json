          "rawQuery": true,
          "rawSql": "SELECT ecosystem_id, agent_id, COUNT(*) AS run_count, MAX(wall_time) AS last_run_time,\nMAX(run_config_version) AS max_config_version_seen, SUM(decisions_completed) AS total_decisions_recorded\nFROM runs\nGROUP BY ecosystem_id, agent_id\nORDER BY ecosystem_id, agent_id;",
