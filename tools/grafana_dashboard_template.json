      "targets": [
        {
          "datasource": {
            "type": "frser-sqlite-datasource",
            "uid": "${DS_SQLITE}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ecosystem_id, agent_id, COUNT(*) AS notebook_entries,\nCOUNT(DISTINCT json_extract(payload_json, '$.text')) AS unique_entries,\nCOUNT(*) - COUNT(DISTINCT json_extract(payload_json, '$.text')) AS duplicate_entries,\nROUND(100.0 * (COUNT(*) - COUNT(DISTINCT json_extract(payload_json, '$.text'))) / NULLIF(COUNT(*), 0), 2) AS duplicate_pct\nFROM events\nWHERE event_type = 'agent.notebook.appended'\nGROUP BY ecosystem_id, agent_id\nORDER BY duplicate_entries DESC, notebook_entries DESC;",
          "refId": "A"
        }
      ],
      "title": "Notebook Duplicate Ratio by Agent",
      "type": "table"
