          {
            "desc": true,
            "displayName": "p95_latency_ms"
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "frser-sqlite-datasource",
            "uid": "${DS_SQLITE}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latencies AS (\n  SELECT ecosystem_id, agent_id,\n    CAST(json_extract(payload_json, '$.metrics.wall_end_ms') AS REAL)\n      - CAST(json_extract(payload_json, '$.metrics.wall_start_ms') AS REAL) AS latency_ms,\n    ROW_NUMBER() OVER (PARTITION BY ecosystem_id, agent_id ORDER BY\n      CAST(json_extract(payload_json, '$.metrics.wall_end_ms') AS REAL)\n      - CAST(json_extract(payload_json, '$.metrics.wall_start_ms') AS REAL)\n    ) AS rn,\n    COUNT(*) OVER (PARTITION BY ecosystem_id, agent_id) AS cnt\n  FROM events\n  WHERE event_type = 'action.executed'\n    AND json_extract(payload_json, '$.metrics.wall_end_ms') IS NOT NULL\n    AND json_extract(payload_json, '$.metrics.wall_start_ms') IS NOT NULL\n)\nSELECT ecosystem_id, agent_id, cnt AS sample_count,\n  MIN(latency_ms) AS min_latency_ms,\n  MAX(CASE WHEN rn = CAST(cnt * 0.5 AS INTEGER) + 1 THEN latency_ms END) AS p50_latency_ms,\n  MAX(CASE WHEN rn = CAST(cnt * 0.95 AS INTEGER) + 1 THEN latency_ms END) AS p95_latency_ms,\n  MAX(latency_ms) AS max_latency_ms\nFROM latencies\nGROUP BY ecosystem_id, agent_id\nORDER BY ecosystem_id, agent_id;",
          "refId": "A"
        }
      ],
      "title": "Decision Latency Distribution (p50/p95)",
      "type": "table"
    },
